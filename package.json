{
  "name": "shulker-panel",
  "displayName": "Shulker Panel",
  "description": "ShulkerRDK 项目任务面板与命令快捷操作| ShulkerRDK Project Task Panel and Command Shortcuts",
  "version": "1.1.0",
  "publisher": "ChouChiu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChouChiu/Shulker-Panel"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "shulkerrdk",
    "minecraft",
    "levitate",
    "task-runner"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "workspaceContains:**/shulker/**/*.lvt"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shulker-panel",
          "title": "Shulker Panel",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "shulker-panel": [
        {
          "type": "tree",
          "id": "shulkerPanel.tasks",
          "name": "Shulker Tasks",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "shulkerPanel.refreshTasks",
        "title": "Refresh Task List",
        "category": "Shulker",
        "icon": "$(refresh)"
      },
      {
        "command": "shulkerPanel.runTask",
        "title": "Run Task",
        "category": "Shulker",
        "icon": "$(play)"
      },
      {
        "command": "shulkerPanel.runCommand",
        "title": "Run Command",
        "category": "Shulker",
        "icon": "$(terminal)"
      },
      {
        "command": "shulkerPanel.openTaskFile",
        "title": "Open Task File",
        "category": "Shulker",
        "icon": "$(go-to-file)"
      },
      {
        "command": "shulkerPanel.copyCommand",
        "title": "Copy Command",
        "category": "Shulker",
        "icon": "$(copy)"
      },
      {
        "command": "shulkerPanel.runQuickPick",
        "title": "Quick Run...",
        "category": "Shulker",
        "icon": "$(run-all)"
      },
      {
        "command": "shulkerPanel.build",
        "title": "Build",
        "category": "Shulker",
        "icon": "$(tools)"
      },
      {
        "command": "shulkerPanel.dev",
        "title": "Dev",
        "category": "Shulker",
        "icon": "$(zap)"
      },
      {
        "command": "shulkerPanel.publish",
        "title": "Publish",
        "category": "Shulker",
        "icon": "$(package)"
      },
      {
        "command": "shulkerPanel.run",
        "title": "Run",
        "category": "Shulker",
        "icon": "$(run-all)"
      },
      {
        "command": "shulkerPanel.projInfo",
        "title": "Project Info",
        "category": "Shulker",
        "icon": "$(info)"
      },
      {
        "command": "shulkerPanel.projChname",
        "title": "Change Project Name",
        "category": "Shulker",
        "icon": "$(edit)"
      },
      {
        "command": "shulkerPanel.projChroot",
        "title": "Change Resource Root",
        "category": "Shulker",
        "icon": "$(folder-opened)"
      },
      {
        "command": "shulkerPanel.projChout",
        "title": "Change Output Dir",
        "category": "Shulker",
        "icon": "$(folder)"
      },
      {
        "command": "shulkerPanel.vermShow",
        "title": "Show Version",
        "category": "Shulker",
        "icon": "$(eye)"
      },
      {
        "command": "shulkerPanel.vermSmajor",
        "title": "Major +1",
        "category": "Shulker",
        "icon": "$(arrow-up)"
      },
      {
        "command": "shulkerPanel.vermSminor",
        "title": "Minor +1",
        "category": "Shulker",
        "icon": "$(arrow-up)"
      },
      {
        "command": "shulkerPanel.vermSfix",
        "title": "Patch +1",
        "category": "Shulker",
        "icon": "$(arrow-up)"
      },
      {
        "command": "shulkerPanel.vermSet",
        "title": "Set Version",
        "category": "Shulker",
        "icon": "$(edit)"
      },
      {
        "command": "shulkerPanel.envList",
        "title": "List Vars",
        "category": "Shulker",
        "icon": "$(list-unordered)"
      },
      {
        "command": "shulkerPanel.envGet",
        "title": "Get Var",
        "category": "Shulker",
        "icon": "$(search)"
      },
      {
        "command": "shulkerPanel.envSet",
        "title": "Set Var",
        "category": "Shulker",
        "icon": "$(edit)"
      },
      {
        "command": "shulkerPanel.envRemove",
        "title": "Remove Var",
        "category": "Shulker",
        "icon": "$(trash)"
      },
      {
        "command": "shulkerPanel.mrpSerialize",
        "title": "Serialize (mrp s)",
        "category": "Shulker",
        "icon": "$(sync)"
      },
      {
        "command": "shulkerPanel.mrpRestore",
        "title": "Restore (mrp r)",
        "category": "Shulker",
        "icon": "$(cloud-download)"
      },
      {
        "command": "shulkerPanel.mrpExport",
        "title": "Export (mrp e)",
        "category": "Shulker",
        "icon": "$(export)"
      },
      {
        "command": "shulkerPanel.mrpAdd",
        "title": "Add Resource (mrp a)",
        "category": "Shulker",
        "icon": "$(add)"
      },
      {
        "command": "shulkerPanel.mrpUpdate",
        "title": "Update Resource (mrp u)",
        "category": "Shulker",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "shulkerPanel.mrpLock",
        "title": "Lock (mrp lock)",
        "category": "Shulker",
        "icon": "$(lock)"
      },
      {
        "command": "shulkerPanel.mrpUnlock",
        "title": "Unlock (mrp unlock)",
        "category": "Shulker",
        "icon": "$(unlock)"
      },
      {
        "command": "shulkerPanel.mrpClean",
        "title": "Clean Cache (mrp clean)",
        "category": "Shulker",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "shulkerPanel.refreshTasks",
          "when": "view == shulkerPanel.tasks",
          "group": "navigation"
        },
        {
          "command": "shulkerPanel.runQuickPick",
          "when": "view == shulkerPanel.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "shulkerPanel.runTask",
          "when": "view == shulkerPanel.tasks && viewItem == taskItem",
          "group": "inline"
        },
        {
          "command": "shulkerPanel.openTaskFile",
          "when": "view == shulkerPanel.tasks && viewItem == taskItem",
          "group": "context@1"
        },
        {
          "command": "shulkerPanel.copyCommand",
          "when": "view == shulkerPanel.tasks && viewItem == taskItem",
          "group": "context@2"
        },
        {
          "command": "shulkerPanel.runCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItem",
          "group": "inline"
        },
        {
          "command": "shulkerPanel.copyCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItem",
          "group": "context@1"
        },
        {
          "command": "shulkerPanel.runCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItemWithInput",
          "group": "inline"
        },
        {
          "command": "shulkerPanel.copyCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItemWithInput",
          "group": "context@1"
        },
        {
          "command": "shulkerPanel.openTaskFile",
          "when": "view == shulkerPanel.tasks && viewItem == configItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Shulker Panel",
      "properties": {
        "shulkerPanel.srdkPath": {
          "type": "string",
          "default": "",
          "description": "Custom path for srdk / srdk.exe. Leave empty to auto-detect from workspace root (srdk.exe on Windows, srdk on Unix)."
        },
        "shulkerPanel.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the task panel when .lvt files change."
        },
        "shulkerPanel.showNonProjectWarning": {
          "type": "boolean",
          "default": true,
          "description": "Show a hint when no ShulkerRDK project is detected."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "node esbuild.config.mts",
    "watch": "node esbuild.config.mts --watch",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "package": "pnpm run build && vsce package --no-dependencies",
    "publish": "pnpm run build && vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.7.0",
    "@types/vscode": "^1.118.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
