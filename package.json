{
  "name": "shulker-panel",
  "displayName": "Shulker Panel",
  "description": "ShulkerRDK 项目任务面板与命令快捷操作| ShulkerRDK Project Task Panel and Command Shortcuts",
  "version": "1.0.0",
  "publisher": "ChouChiu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LiPolymer/Shulker-in-editor"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "shulkerrdk",
    "minecraft",
    "levitate",
    "task-runner"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "workspaceContains:**/shulker/**/*.lvt"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shulker-panel",
          "title": "%viewsContainers.activitybar.shulker-panel.title%",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "shulker-panel": [
        {
          "type": "tree",
          "id": "shulkerPanel.tasks",
          "name": "%views.shulkerPanel.tasks.name%",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "shulkerPanel.refreshTasks",
        "title": "%command.shulkerPanel.refreshTasks.title%",
        "category": "Shulker",
        "icon": "$(refresh)"
      },
      {
        "command": "shulkerPanel.runTask",
        "title": "%command.shulkerPanel.runTask.title%",
        "category": "Shulker",
        "icon": "$(play)"
      },
      {
        "command": "shulkerPanel.runCommand",
        "title": "%command.shulkerPanel.runCommand.title%",
        "category": "Shulker",
        "icon": "$(terminal)"
      },
      {
        "command": "shulkerPanel.openTaskFile",
        "title": "%command.shulkerPanel.openTaskFile.title%",
        "category": "Shulker",
        "icon": "$(go-to-file)"
      },
      {
        "command": "shulkerPanel.copyCommand",
        "title": "%command.shulkerPanel.copyCommand.title%",
        "category": "Shulker",
        "icon": "$(copy)"
      },
      {
        "command": "shulkerPanel.runQuickPick",
        "title": "%command.shulkerPanel.runQuickPick.title%",
        "category": "Shulker",
        "icon": "$(run-all)"
      },
      {
        "command": "shulkerPanel.build",
        "title": "%command.shulkerPanel.build.title%",
        "category": "Shulker",
        "icon": "$(tools)"
      },
      {
        "command": "shulkerPanel.dev",
        "title": "%command.shulkerPanel.dev.title%",
        "category": "Shulker",
        "icon": "$(zap)"
      },
      {
        "command": "shulkerPanel.publish",
        "title": "%command.shulkerPanel.publish.title%",
        "category": "Shulker",
        "icon": "$(package)"
      },
      {
        "command": "shulkerPanel.run",
        "title": "%command.shulkerPanel.run.title%",
        "category": "Shulker",
        "icon": "$(run-all)"
      },
      {
        "command": "shulkerPanel.projInfo",
        "title": "%command.shulkerPanel.projInfo.title%",
        "category": "Shulker",
        "icon": "$(info)"
      },
      {
        "command": "shulkerPanel.projChname",
        "title": "%command.shulkerPanel.projChname.title%",
        "category": "Shulker",
        "icon": "$(edit)"
      },
      {
        "command": "shulkerPanel.projChroot",
        "title": "%command.shulkerPanel.projChroot.title%",
        "category": "Shulker",
        "icon": "$(folder-opened)"
      },
      {
        "command": "shulkerPanel.projChout",
        "title": "%command.shulkerPanel.projChout.title%",
        "category": "Shulker",
        "icon": "$(folder)"
      },
      {
        "command": "shulkerPanel.vermShow",
        "title": "%command.shulkerPanel.vermShow.title%",
        "category": "Shulker",
        "icon": "$(eye)"
      },
      {
        "command": "shulkerPanel.vermSmajor",
        "title": "%command.shulkerPanel.vermSmajor.title%",
        "category": "Shulker",
        "icon": "$(arrow-up)"
      },
      {
        "command": "shulkerPanel.vermSminor",
        "title": "%command.shulkerPanel.vermSminor.title%",
        "category": "Shulker",
        "icon": "$(arrow-up)"
      },
      {
        "command": "shulkerPanel.vermSfix",
        "title": "%command.shulkerPanel.vermSfix.title%",
        "category": "Shulker",
        "icon": "$(arrow-up)"
      },
      {
        "command": "shulkerPanel.vermSet",
        "title": "%command.shulkerPanel.vermSet.title%",
        "category": "Shulker",
        "icon": "$(edit)"
      },
      {
        "command": "shulkerPanel.envList",
        "title": "%command.shulkerPanel.envList.title%",
        "category": "Shulker",
        "icon": "$(list-unordered)"
      },
      {
        "command": "shulkerPanel.envGet",
        "title": "%command.shulkerPanel.envGet.title%",
        "category": "Shulker",
        "icon": "$(search)"
      },
      {
        "command": "shulkerPanel.envSet",
        "title": "%command.shulkerPanel.envSet.title%",
        "category": "Shulker",
        "icon": "$(edit)"
      },
      {
        "command": "shulkerPanel.envRemove",
        "title": "%command.shulkerPanel.envRemove.title%",
        "category": "Shulker",
        "icon": "$(trash)"
      },
      {
        "command": "shulkerPanel.mrpSerialize",
        "title": "%command.shulkerPanel.mrpSerialize.title%",
        "category": "Shulker",
        "icon": "$(sync)"
      },
      {
        "command": "shulkerPanel.mrpRestore",
        "title": "%command.shulkerPanel.mrpRestore.title%",
        "category": "Shulker",
        "icon": "$(cloud-download)"
      },
      {
        "command": "shulkerPanel.mrpExport",
        "title": "%command.shulkerPanel.mrpExport.title%",
        "category": "Shulker",
        "icon": "$(export)"
      },
      {
        "command": "shulkerPanel.mrpAdd",
        "title": "%command.shulkerPanel.mrpAdd.title%",
        "category": "Shulker",
        "icon": "$(add)"
      },
      {
        "command": "shulkerPanel.mrpUpdate",
        "title": "%command.shulkerPanel.mrpUpdate.title%",
        "category": "Shulker",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "shulkerPanel.mrpLock",
        "title": "%command.shulkerPanel.mrpLock.title%",
        "category": "Shulker",
        "icon": "$(lock)"
      },
      {
        "command": "shulkerPanel.mrpUnlock",
        "title": "%command.shulkerPanel.mrpUnlock.title%",
        "category": "Shulker",
        "icon": "$(unlock)"
      },
      {
        "command": "shulkerPanel.mrpClean",
        "title": "%command.shulkerPanel.mrpClean.title%",
        "category": "Shulker",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "shulkerPanel.refreshTasks",
          "when": "view == shulkerPanel.tasks",
          "group": "navigation"
        },
        {
          "command": "shulkerPanel.runQuickPick",
          "when": "view == shulkerPanel.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "shulkerPanel.runTask",
          "when": "view == shulkerPanel.tasks && viewItem == taskItem",
          "group": "inline"
        },
        {
          "command": "shulkerPanel.openTaskFile",
          "when": "view == shulkerPanel.tasks && viewItem == taskItem",
          "group": "context@1"
        },
        {
          "command": "shulkerPanel.copyCommand",
          "when": "view == shulkerPanel.tasks && viewItem == taskItem",
          "group": "context@2"
        },
        {
          "command": "shulkerPanel.runCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItem",
          "group": "inline"
        },
        {
          "command": "shulkerPanel.copyCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItem",
          "group": "context@1"
        },
        {
          "command": "shulkerPanel.runCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItemWithInput",
          "group": "inline"
        },
        {
          "command": "shulkerPanel.copyCommand",
          "when": "view == shulkerPanel.tasks && viewItem == commandItemWithInput",
          "group": "context@1"
        },
        {
          "command": "shulkerPanel.openTaskFile",
          "when": "view == shulkerPanel.tasks && viewItem == configItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Shulker Panel",
      "properties": {
        "shulkerPanel.srdkPath": {
          "type": "string",
          "default": "",
          "description": "%configuration.shulkerPanel.srdkPath.description%"
        },
        "shulkerPanel.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shulkerPanel.autoRefresh.description%"
        },
        "shulkerPanel.showNonProjectWarning": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shulkerPanel.showNonProjectWarning.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "node esbuild.config.mts",
    "watch": "node esbuild.config.mts --watch",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "package": "pnpm run build && vsce package --no-dependencies",
    "publish": "pnpm run build && vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.118.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
